{"trainType":"交叉培养","grade":"2020","education":{"id":2,"nameZh":"本科"},"studentType":{"id":4,"nameZh":"普通"},"department":{"id":87,"code":"203","nameZh":"物理学院"},"major":{"id":24,"code":"00401","nameZh":"物理学"},"majorDirection":null,"requiredCredits":0,"awardDegree":true,"beginSemester":"2020年秋季学期","directionGen":true,"moduleTree":[{"self":{"id":31631,"parent":31630,"type":"专业核心课程","typeEn":"Major Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":2,"requiredCredits":0,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":null,"ref":null,"index":0},"isLeaf":false,"children":[{"self":{"id":31632,"parent":31631,"type":"公共","typeEn":"Common Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":12,"requiredCourseNum":3,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":4,"course":{"id":11068,"code":"022062","nameZh":"热力学与统计物理A","nameEn":"Thermodynamics and Statistical Physics A","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>本课程由两部分组成，前一部分是热力学，介绍温度、热力学三定律、热力学函数的应用、相变基础理论。后一部分是统计物理，首先介绍玻尔兹曼统计、费米统计、玻色统计及其经典极限，进而给出系综理论，并且介绍非平衡情况下的玻尔兹曼输运方程、涨落理论和布朗运动等。</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":5,"course":{"id":12310,"code":"022057","nameZh":"电动力学","nameEn":"Electrodynamics","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>本课程系统介绍宏观电磁场的基本理论，着重于电磁现象的基本规律、物理概念和研究方<br />法的概述。重点讨论了电磁现象的普遍规律，分析了静态电场、磁场的基本性质和求解电<br />场和磁场问题的一些基本方法；讨论了电磁波的辐射及其传播规律，给出了一般情况下电<br />磁势的概念和辐射电磁场的计算方法；讨论了狭义相对论原理，通过对惯性参考系物理规<br />律协变的要求，给出了电磁场基本方程的四维形式；最后介绍了带电粒子和电磁场的相互<br />作用规律。</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":4,"course":{"id":12916,"code":"022392","nameZh":"理论力学A","nameEn":"Theoretical Mechanics A","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"理论力学是一门从宏观系统的能量或其他具有能量量纲的物理量出发，通过分析的手段（例如变分法），研究系统的机械运动规律的课程。其理论基础是牛顿运动定律，即牛顿力学。该课程涉及分析力学与刚体运动，主要内容包括最小作用量原理、拉格朗日力学、哈密顿力学、质点在有心力场中的运动、两体碰撞与散射、多自由度系统的小振动和刚体的运动。","courseGradation":"专业基础","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}}],"public":null,"ref":null,"index":0},"isLeaf":true},{"self":{"id":31633,"parent":31631,"type":"差异性课程","typeEn":"Different Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":3,"requiredCredits":0,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":null,"ref":null,"index":1},"isLeaf":false,"children":[{"self":{"id":31634,"parent":31633,"type":"课程分组","typeEn":"Course Group","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":0,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":120,"theoryPeriods":120,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":6,"course":{"id":9504,"code":"022148","nameZh":"量子力学A","nameEn":"Quantum Mechanics A","totalPeriods":120,"theoryPeriods":120,"credits":6,"introduction":"<p>本课程的目的是引导学生进入微观尺度下的迷人的量子物理世界。我们将学习非相对论量子力学的基本物理原理和基本数学工具，并将这些简洁的基本理论应用于各种有趣的物理现象。</p>\r\n<p>首先我们学习量子系统状态的描述和运动规律。具体包含了希尔伯特空间，态矢与狄拉克记号，观察量和算符理论，表象变换，运动方程，测量塌缩和不确定原理。在这里，我们会学习求解一维势阱，简谐振子，氢原子，二能级系统等解析可解问题。</p>\r\n<p>然后我们进一步学习更加精美的理论：对称性理论和角动量理论。通过对称性和不变性我们可以更加深刻的理解力学观察量的含义；对角动量理论的学习提供了一个熟练使用力学观察量的平台，同时我们将了解到一个新的自由度，粒子的自旋角动量。</p>\r\n<p>接着我们学习如何应用基本理论到实际问题中。这些方法包括：不含时微扰论，变分法，含时微扰论。同时我们将近似方法应用到非束缚态过程上，形成相应的散射理论。</p>\r\n<p>最后我们将初步了解多个微观全同粒子在一起时展现出来的奇异现象。不可区分性和交换对称性规定了这些多粒子态的统计特性，使得我们可以将微观粒子划分为两大类:玻色子和费米子。这时将学习二次量子化工具来处理全同粒子系统，并将电磁场进行量子化。</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（开卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":4,"course":{"id":9623,"code":"022059","nameZh":"量子力学B","nameEn":"Quantum Mechanics B","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>本课程的目的是引导学生进入微观尺度下的迷人量子物理世界。我们将学习非相对论量子力学的基本物理原理和基本数学工具，并将这些简洁的基本理论应用于各种有趣的物理现象。</p>\n<p>首先我们学习如何描述一个量子系统的状态，它是如何运动演化的，我们如何观察测量它。这具体包括了狄拉克左右矢，薛定谔运动方程，海森堡运动方程，力学观察量和表象变换，测量塌缩和不确定原理。在这里，我们会学习求解一维势，简谐振子，氢原子，二能级系统；这些都是解析可解问题。</p>\n<p>然后我们学习如何应用基本理论到实际问题中。通过一些近似方法，在很好的精度下减轻物理模型计算的复杂性。这些方法包括：不含时微扰论，变分法。这些方法是解决实际问题的强有力工具。</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}}],"public":null,"ref":null,"index":0},"isLeaf":true},{"self":{"id":31636,"parent":31633,"type":"课程分组","typeEn":"Course Group","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":0,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":40,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":2,"course":{"id":10193,"code":"203003","nameZh":"固体物理C","nameEn":"Solid State Physics C","totalPeriods":40,"theoryPeriods":40,"credits":2,"introduction":"固体物理学是研究固体性质的基础课程。主要内容包括晶体结构：晶体对称性、倒易空间和晶体结构衍射测量；晶格振动：声子和晶体热学性质；能带论：晶体近自由电子和紧束缚近似下能带；金属电子论等。","courseGradation":"专业核心","seasons":"春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":12700,"code":"022118","nameZh":"固体物理B","nameEn":"Solid State Physics B","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>固体物理学是研究固体性质的基础课程。主要内容包括晶体结构：晶体对称性、倒易空间和晶体结构衍射测量；晶格振动：声子和晶体热学性质；能带论：晶体近自由电子和紧束缚近似下能带；金属和半导体电子论。</p>","courseGradation":"专业核心","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":5,"course":{"id":13596,"code":"002001","nameZh":"固体物理A","nameEn":"Solid State Physics A","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>固体物理学是研究固体性质的基础课程。主要内容包括晶体结构和晶体结合：晶体对称性、倒易空间、晶体结构衍射测量和晶体结合；晶格振动：声子和晶体热学性质；能带论：晶体近自由电子和紧束缚近似下能带；金属电子论和半导体电子论；晶体中电子在外场中的运动等。</p>","courseGradation":"专业核心","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":62,"code":"002","nameZh":"物理学系"}}],"public":null,"ref":null,"index":1},"isLeaf":true},{"self":{"id":31635,"parent":31633,"type":"课程分组","typeEn":"Course Group","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":0,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":6940,"code":"004040","nameZh":"计算物理B","nameEn":"Computational Physics B","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程的教学内容包括计算物理领域的重要基本概念、数学基础、方法与应用。内容涉及在传统物理课题中常用的数值计算方法，如：偏微分方程的数值求解方法、计算机模拟方法中的随机模拟方法-蒙特卡洛方法和确定性模拟方法-分子动力学方法以及神经元网络方法。而且，还包括计算机符号处理系统及其在理论和实验物理领域中的应用。这门课程虽然主要是针对粒子物理、原子核物理和等离子体物理等专业方向的学生，但是对于许多学习物理化学、材料科学、工程物理等专业的本科生和研究生也都十分有益。</p>","courseGradation":"专业核心","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":63,"code":"004","nameZh":"近代物理系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":7245,"code":"203002","nameZh":"计算物理C","nameEn":"Computational Physics C","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"计算物理（C）课程讲解基于物理、化学模型的计算机数值模拟方法在分子生物物理中的应用，特别是在生物大分子结构、动力学及分子设计中的应用。主要内容包括分子力学能量函数、蒙特卡洛模拟、分子动力学模拟的基本原理与方法；自由能模拟、反应路径模拟、多尺度模拟等模拟技术；生物分子构象分析与分子设计方法。","courseGradation":"专业核心","seasons":"秋"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":11873,"code":"022012","nameZh":"计算物理A","nameEn":"Computational Physics A","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程系统介绍了物理学研究中的一些主要计算模拟方法，如：Monte Carlo方法、迭代方法、有限差分法、有限元素法、分子动力学方法、密度泛函理论和计算方法，着重论述了各算法在包括凝聚态物理、统计物理、量子物理、非线性物理等众多领域中的应用。通过对各种研究问题中涉及的物理原理和概念的讲解、计算模型的建立、数值计算方法和技巧的剖析以及计算结果的物理分析等，使学生了解如何采用计算物理方法进行科学研究。本课程不仅针对于物理学各分支专业的本科生，也可为化学物理、材料科学和工程等专业的本科生和研究生打下良好的基础。</p>","courseGradation":"专业核心","seasons":"秋,春"},"terms":["0--"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}}],"public":null,"ref":null,"index":2},"isLeaf":true}]}]}]}