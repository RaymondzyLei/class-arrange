{"trainType":"第二学士学位","grade":"2020","education":{"id":2,"nameZh":"本科"},"studentType":{"id":62,"nameZh":"第二学士学位"},"department":{"id":73,"code":"017","nameZh":"统计与金融系"},"major":{"id":12,"code":"01702","nameZh":"金融学"},"majorDirection":null,"requiredCredits":60,"awardDegree":false,"beginSemester":"2020年秋季学期","directionGen":false,"moduleTree":[{"self":{"id":32707,"parent":32706,"type":"必修","typeEn":"Compulsory Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":34,"requiredCourseNum":11,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":15531,"code":"015006","nameZh":"宏观经济学","nameEn":"Macroeconomics","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>宏观经济学是经济学的一个分支，它研究整体经济的行为，包括市场、企业、消费者和政府。宏观经济学考察整个经济的现象，如通货膨胀、物价水平、经济增长率、国民收入、国内生产总值(GDP)和失业率的变化。宏观经济学解决的一些关键问题包括：是什么导致了失业？是什么导致了通货膨胀？什么创造或刺激经济增长？宏观经济学试图衡量一个经济体的表现，了解驱动它的力量，并预测如何改善表现。</p>\n<p>宏观经济学是经济管理及金融学等专业的重要基础理论课，通过本课程学习，使学生对宏观经济理论框架有一个总体性认识，能够运用基本原理分析实际问题，对政府宏观经济政策有正确的理解。本课程与一般本科宏观经济学教学不同的是，本课程拟针对中国科大本科学生的特点，不仅注重基本概念与基本理论的训练，还在相关章节中融入中高级经济学的内容和分析工具，增强学生数理分析能力。</p>","courseGradation":"专业基础","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":71,"code":"015","nameZh":"工商管理系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":11950,"code":"015146","nameZh":"会计学","nameEn":"Accounting","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程旨在为学生提供全面系统的会计学知识，涵盖会计学的基础理论、实务操作和财务管理等方面。通过课程学习，学生将掌握会计的基本概念、会计的类别、工业企业会计核算的基本内容、商品流通企业核算的基本内容、账户分类、会计凭证、会计账簿、账务处理的程序以及财产清查、会计报表并简要介绍会计在企业管理中的作用以及当代管理会计的新发展。此外，课程还将介绍会计报表的编制方法和分析技巧，培养学生独立分析财务状况和经营业绩的能力，为其未来从事会计和财务管理工作打下坚实的基础。</p>","courseGradation":"专业基础","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":71,"code":"015","nameZh":"工商管理系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":8098,"code":"017022","nameZh":"货币银行学","nameEn":"Money and Banking","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"本课程主要介绍货币银行学的基本理论，并且结合所学理论分析现实的金融问题。课程内容包括：货币及其制度；信用与利率；金融市场与金融机构体系；商业银行理论；中央银行理论与货币政策；货币供给与需求理论；通货膨胀理论。","courseGradation":"专业核心","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":12573,"code":"017046","nameZh":"国际金融","nameEn":"International Finance","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"国际金融学是一门学习国际金融学的一般知识、经典理论和内外均衡分析方法的课程，包括国际收支和国际收支平衡表、汇率、内外均衡的短期调节和中长期调节、外汇管理制度和政策调节、金融全球化对内外均衡的冲击。","courseGradation":"专业选修","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"闭卷","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":20,"periodsPerWeek":3,"course":{"id":13035,"code":"017123","nameZh":"计量经济学","nameEn":"Econometrics","totalPeriods":80,"theoryPeriods":60,"credits":3.5,"introduction":"<p>计量经济学是在对社会经济现象作定性分析的基础上，探讨如何运用模型方法定量描述和分析具有随机性特征的经济变量关系的经济学分支，是经济类各专业的核心课程。通过本课程的教学，要求学生达到了解计量经济学作为现代经济学的重要组成部分所具有的特征与地位，了解计量经济分析方法在经济学科的发展和实际经济工作中的作用；掌握计量经济学分析经济问题的基本思想，掌握计量经济学建模的基本原理；熟知计量经济分析的基本内容和工作程序；具备运用计量经济分析软件和计量经济分析方法对实际经济问题作定量分析的初步能力；并打下进一步学习更高层次计量经济学课程的基础。</p>","courseGradation":"专业基础","seasons":"秋"},"terms":["2秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":14429,"code":"017124","nameZh":"金融机构与金融市场","nameEn":"Financial Institutions and Markets","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程主要包括金融市场与金融机构两部分内容。金融市场部分包括金融市场基础、货币市场、债券市场、股票市场、外汇市场。金融机构部分包括金融机构基金、中央银行、商业银行、共同基金、保险公司和养老基金、投资银行。</p>","courseGradation":"专业选修","seasons":"秋,春"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":6869,"code":"017134","nameZh":"公司金融","nameEn":"Corporate Finance","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程主要向学生介绍公司金融学的基本原理和分析方法，让学生掌握如何用公司金融学的基本原理和简单的模型分析公司管理中的金融问题。</p>","courseGradation":"专业核心","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":13037,"code":"017139","nameZh":"金融经济学基础","nameEn":"Fundamentals of Financial Economics","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"\"本课程重点阐释现代金融经济学的基础理论，包括偏好、效用与风险厌恶度量、Arrow-Debreu经济、均衡资产定价、套利资产定价及M-M理论。课程也将涉及市场微观结构和行为金融学的一些基础理论。通过本课程的学习，学生应该能够清晰地理解在不确定情况下个人消费和投资组合决策的主要理论成果，以及对证券定价的意义。\"","courseGradation":"专业核心","seasons":"秋,春"},"terms":["2秋"],"remark":null,"examMode":"笔试（半开卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":13305,"code":"017141","nameZh":"微观经济学A","nameEn":"Microeconomics A","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"在学生掌握了经济学原理的基础上，本课程将介绍微观经济学的理论工具和分析方法，使得学生能够运用简单的经济学模型分析现实经济问题，为更深入地学习后续专业课程打下基础。本课程的主要内容包括边际与均衡分析，选择与需求，生产与供给，市场结构，要素市场，一般均衡，不确定性与信息，外部性，以及福利经济学等。","courseGradation":"专业基础","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":20,"periodsPerWeek":4,"course":{"id":12572,"code":"017165","nameZh":"时间序列分析B","nameEn":"Time Series Analysis B","totalPeriods":80,"theoryPeriods":60,"credits":3.5,"introduction":"<p>时间序列分析是一门学习如何对经济数据建模，从而预测、分析和假设检验的课程，内容包括差分方程、平稳时间序列建模（ARMA模型），波动性建模（GARCH模型），包含趋势的模型、多方程时间序列模型和协整和误差修正模型。</p>","courseGradation":"专业选修","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":13126,"code":"017703","nameZh":"金融衍生品","nameEn":"Financial Derivatives","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"该课程是工商管理专业的一门专业选修课。该课程主要介绍：衍生品的含义、种类与发展背景；无套利定价原理、远期、期货、期权和互换的定价与应用等，并且结合所学理论分析现实的金融问题。","courseGradation":"专业选修","seasons":"秋"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}}],"public":null,"ref":null,"index":0},"isLeaf":true},{"self":{"id":32708,"parent":32706,"type":"选修","typeEn":"Selective","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":12,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":false,"weeks":18,"totalPeriods":40,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":2,"course":{"id":11309,"code":"015708","nameZh":"财务分析","nameEn":"Financial Analysis","totalPeriods":40,"theoryPeriods":40,"credits":2,"introduction":"财务分析是以会计核算和报表资料及其他相关资料为依据，采用一系列专门的分析技术和方法，对企业的财务状况和经营成果、现金流量等方面进行分析，为与企业有利害关系的各方评价企业过去，反映企业现状，预测企业未来，做出正确决策，提供准确信息或依据的经济应用学科。","courseGradation":"专业核心","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":71,"code":"015","nameZh":"工商管理系"}},{"compulsory":false,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":10489,"code":"015710","nameZh":"博弈论与信息经济学","nameEn":"Game Theory and Information Economics","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>博弈论是研究决策主体的行为产生相互作用时各个主体之间的最优决策以及决策均衡问题。博弈论在西方经济学的教科书中已是一门被广泛接纳的理论知识课程。博弈论分为合作博弈和非合作博弈，本课程讲授的是非合作博弈。博弈论之所以成为主流经济学的一个重要组成部分，是因为信息问题在经济学中变得越来越重要。从非合作博弈理论来看，主体内容包括：完全信息静态博弈，完全信息动态博弈，不完全信息静态博弈和不完全信息动态博弈。</p>\r\n<p>信息经济学是非对称信息博弈论在经济学中的应用，可以简单地理解为：给定一定的信息结构，什么是最优的契约安排。信息的非对称性可以从两个角度划分：非对称信息发生的事件以及非对成信息发生的内容。研究事前非对称信息博弈的模型称为逆向选择模型，研究事后非对称信息博弈的模型称为道德风险模型。研究不可观测行动的模型称为隐藏行动模型，研究不可观测知识的模型称为隐藏知识模型（或隐藏信息模型）。在委托人-代理人的框架下，信息经济学的主体内容包括：隐藏行动的道德风险模型，隐藏信息的道德风险模型，逆向选择模型，信号传递模型，信息甄别模型。</p>","courseGradation":"专业基础","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":71,"code":"015","nameZh":"工商管理系"}},{"compulsory":false,"weeks":18,"totalPeriods":80,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":20,"periodsPerWeek":4,"course":{"id":7431,"code":"016120","nameZh":"运筹学I","nameEn":"Operations Research I","totalPeriods":80,"theoryPeriods":60,"credits":3.5,"introduction":"运筹学运用科学方法，主要是用数学方法去研究客观世界的多种运行系统中所发生的复杂问题。其独特之处在于为现实或未来系统建立数学模型，并据此进行定量分析，从而得到系统最优运行或最优设计方案。本课程主要讲授线性规划、整体规划、非线性规划、动态规划等运筹学分枝中的基础模型和方法。","courseGradation":"专业基础","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":72,"code":"016","nameZh":"管理科学系"}},{"compulsory":false,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":7899,"code":"017131","nameZh":"随机过程A","nameEn":"Stochastic Processes A","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程主要介绍随机过程的概念、方法和应用, 内容包括Poisson过程、Markov过程、平稳过程、Brown运动、随机微分方程和和鞅过程及其性质等。</p>","courseGradation":"专业基础","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":false,"weeks":18,"totalPeriods":40,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":2,"course":{"id":11281,"code":"017137","nameZh":"金融学导论","nameEn":"Introduction to Finance","totalPeriods":40,"theoryPeriods":40,"credits":2,"introduction":"<p>本课程以Z. Bodie和R. C. Merton共同编著的教材：《Finance》为主线，采用授课的方式，有选择地展开教学。教学内容包括：</p>\r\n<ol>\r\n<li>金融学概述&mdash;&mdash;介绍金融学的含义和金融体系；</li>\r\n<li>资源和时间的分配&mdash;&mdash;货币的时间价值和现金流贴现分析、生命周期理财计划、投资项目分析；</li>\r\n<li>价值评估模型 &mdash;&mdash;资产价值评估原则、债券和股票的价值评估；</li>\r\n<li>风险管理与投资组合理论&mdash;&mdash;风险管理的含义和方法</li>\r\n</ol>\r\n<p>&nbsp;&nbsp;</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":false,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":13036,"code":"017153","nameZh":"金融风险管理","nameEn":"Financial Risk Management","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"本课程以金融风险管理的理论为主，重点介绍金融风险管理领域中的市场风险、信用风险、操作风险、流动性风险、利率风险以及外汇风险等的定义以及度量方法。并介绍了金融风险管理的一般过程、金融风险辨识、常见的一些金融风险度量方法、金融机构的风险管理、金融衍生工具与金融风险管理的关系等。","courseGradation":"专业选修","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":false,"weeks":18,"totalPeriods":100,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":40,"periodsPerWeek":4,"course":{"id":12202,"code":"017160","nameZh":"实用统计软件","nameEn":"Applied Statistical Software","totalPeriods":100,"theoryPeriods":60,"credits":4,"introduction":"\"实用统计软件课程讲授R和SAS两个统计软件。其中R的课时占70%，SAS的课时占30%。本课程介绍两个主要的统计软件R和SAS。R以其易学，灵活和内容丰富的特点使其适用于在个人计算机上进行统计分析和计算，因而在大学和科研机构得到了广泛的应用。SAS主要用于工业界。目前在美国SAS被普遍应用于制药公司，银行和保险业。本课程将以介绍R语言为主。我们详细介绍了R的编程，数据的整理和分析，各种统计模拟方法，及其它有趣的应用。整个课程强调以例子和作图展示统计理论的内涵。对于SAS，我们介绍了SAS语言的主要部分。学过本课程以后可以进行简单的SAS编程。\"","courseGradation":"专业选修","seasons":"秋,春"},"terms":["2秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}},{"compulsory":false,"weeks":18,"totalPeriods":80,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":20,"periodsPerWeek":4,"course":{"id":12571,"code":"017163","nameZh":"多元统计分析B","nameEn":"Multivariate Analysis B","totalPeriods":80,"theoryPeriods":60,"credits":3.5,"introduction":"本课程主要是介绍多元统计分析的各种有着广泛应用的经典和现代的模型和方法。 内容包括关于多元正态分布以及它的均值向量的统计推断，协方差结构分析中的主成分分析，因子分析，分类和分组方法中的判别分析与聚类分析等。 以及介绍了如何使用统计软件在计算机上处理数据。","courseGradation":"专业基础","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":73,"code":"017","nameZh":"统计与金融系"}}],"public":null,"ref":null,"index":1},"isLeaf":true},{"self":{"id":32710,"parent":32706,"type":"毕业论文","typeEn":"Thesis","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":8,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":320,"theoryPeriods":0,"praticePeriods":0,"experimentPeriods":320,"periodsPerWeek":0,"course":{"id":143874,"code":"THESIS-S","nameZh":"毕业论文","nameEn":"Graduation Thesis","totalPeriods":320,"theoryPeriods":0,"credits":8,"introduction":"无","courseGradation":"专业核心","seasons":"秋,春"},"terms":["2春"],"remark":null,"examMode":"其他","department":{"id":59,"code":"601","nameZh":"教务处"}}],"public":null,"ref":null,"index":2},"isLeaf":true},{"self":{"id":32709,"parent":32706,"type":"自由选修课","typeEn":"Free Selectives","major":"--","majorDirection":"--","remark":"全校本科生课程及本研贯通课程","requiredSubModuleNum":0,"requiredCredits":6,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":null,"ref":null,"index":3},"isLeaf":true}]}