"--","remark":null,"requiredSubModuleNum":2,"requiredCredits":0,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":58810,"ref":null,"index":1},"isLeaf":false,"children":[{"self":{"id":62714,"parent":62713,"type":"英语通修拓展课","typeEn":"English Extended Courses","major":"--","majorDirection":"--","remark":"拓展类选修课程待更新","requiredSubModuleNum":0,"requiredCredits":2,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":58813,"ref":null,"index":0},"isLeaf":true},{"self":{"id":62715,"parent":62713,"type":"必修","typeEn":"Compulsory Courses","major":"--","majorDirection":"--","remark":"读写进阶课程待添加","requiredSubModuleNum":0,"requiredCredits":1,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":58812,"ref":null,"index":1},"isLeaf":true}]},{"self":{"id":62716,"parent":62711,"type":"英语通修G3","typeEn":"English G3","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":2,"requiredCredits":0,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":58811,"ref":null,"index":2},"isLeaf":false,"children":[{"self":{"id":62717,"parent":62716,"type":"英语通修拓展课","typeEn":"English Extended Courses","major":"--","majorDirection":"--","remark":"拓展类选修课程待更新","requiredSubModuleNum":0,"requiredCredits":2,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":58815,"ref":null,"index":0},"isLeaf":true},{"self":{"id":62718,"parent":62716,"type":"必修","typeEn":"Compulsory Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":2,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":58814,"ref":null,"index":1},"isLeaf":true}]}]},{"self":{"id":62719,"parent":62699,"type":"数学通修","typeEn":"Mathematics-General","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":16,"requiredCourseNum":3,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":120,"theoryPeriods":120,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":6,"course":{"id":8385,"code":"MATH1007","nameZh":"数学分析(B2)","nameEn":"Mathematical Analysis B2","totalPeriods":120,"theoryPeriods":120,"credits":6,"introduction":"<p>《数学分析》B 系列共有三门课程组成，分别标记为（B1）、（B2）、（B3）。其中《数学分析（B1）》和《数学分析（B2）》面向理工科一年级学生，主要讲授数学分析和微积分基本内容，突出基本思想，基本方法，基本计算和推导。内容相对完整，是理工科学生必备的数学分析和微积分的基本知识。《数学分析（B3）》从内容、观点和方法上，是前两课程的深化、提升和拓展，主要针对大学一年后选择数学专业或其他感兴趣的学生。</p>\n<p>数学分析(B2)课程的内容包括空间解析几何，多变量函数的连续性，多变量函数和向量值函数的微分学，隐函数和反函数定理，多变量函数的Taylor展开、极值和条件极值，空间曲线和曲面，向量场的梯度、旋度和散度，重积分，曲线积分和曲面积分，格林定理、高斯-斯托克斯定理，保守场，微分形式简介，Fourier 分析，广义积分和含参变量积分。</p>","courseGradation":"通修","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":2,"code":"001","nameZh":"数学科学学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":4,"course":{"id":9498,"code":"MATH1009","nameZh":"线性代数(B1)","nameEn":"Linear Algebra B1","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>课程主要讲述线性代数的基本知识，内容包括：线性方程组的求解，矩阵和行列式运算，线性空间与线性变换理论，欧氏空间与二次型等。</p>\n<p>&nbsp;</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":2,"code":"001","nameZh":"数学科学学院"}},{"compulsory":true,"weeks":18,"totalPeriods":120,"theoryPeriods":120,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":6,"course":{"id":15584,"code":"MATH1006","nameZh":"数学分析(B1)","nameEn":"Mathematical Analysis B1","totalPeriods":120,"theoryPeriods":120,"credits":6,"introduction":"<p>《数学分析》B 系列共有三门课程组成，分别标记为（B1）、（B2）、（B3）。其中《数学分析（B1）》和《数学分析（B2）》面向理工科一年级学生，主要讲授数学分析和微积分基本内容，突出基本思想，基本方法，基本计算和推导。内容相对完整，是理工科学生必备的数学分析和微积分的基本知识。《数学分析（B3）》从内容、观点和方法上，是前两课程的深化、提升和拓展，主要针对大学一年后选择数学专业或其他感兴趣的学生。</p>\r\n<p>《数学分析》（B1）的内容如下：实数简介；数列极限以及实数完备性若干等价命题；函数的极限、连续性和一致连续性；一元函数的导数和微分、微分中值定理、泰勒定理、函数的极值、凸性和曲率；不定积分；一元函数的积分、牛顿－莱伯尼兹公式和可积函数类；一阶和二阶可积常微分方程初步；数项级数的绝对收敛和条件收敛；函数项级数的一致收敛性等解析性质以及幂级数等。</p>","courseGradation":"通修","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":2,"code":"001","nameZh":"数学科学学院"}}],"public":null,"ref":null,"index":4},"isLeaf":true},{"self":{"id":62720,"parent":62699,"type":"物理通修","typeEn":"Physics-General","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":18.5,"requiredCourseNum":7,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":null,"totalPeriods":20,"theoryPeriods":0,"praticePeriods":0,"experimentPeriods":20,"periodsPerWeek":null,"course":{"id":143764,"code":"PHYS1009B","nameZh":"大学物理-综合实验B","nameEn":"College Physics – Comprehensive Experimentation B","totalPeriods":20,"theoryPeriods":0,"credits":0.5,"introduction":"<p>本课程以综合性实验和设计性实验为主进行实验教学。</p>\r\n<p>运用实验方法和技能研究力、热、电、光等物理量，并且逐步引入现代物理实验技术。在实验内容上，增加实验的综合性和设计性，由验证性实验逐步过渡到在教师指导下，学生自己设计实验方案并完成实验，从而培养学生综合分析问题和解决问题的能力。通过引入探究性实验，培养学生的团队合作精神和创新能力。</p>\r\n<p>基本要求：课前预习，了解、掌握实验原理和实验方法，并设计实验方案；实验过程中，操作、观察现象、数据的获得、分析确定数据取舍等环节；实验后认真分析、总结，完成实验报告，最终采取答辩方式获取成绩。</p>\r\n<p>课时安排：实验16学时，讨论总结4学时。从提供的系列实验中由学院指定（中心推荐）2个实验系列（每个系列完成2个实验项目）。</p>","courseGradation":"通修","seasons":"秋"},"terms":["2秋"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":56,"code":"042","nameZh":"物理实验教学中心"}},{"compulsory":true,"weeks":null,"totalPeriods":40,"theoryPeriods":0,"praticePeriods":0,"experimentPeriods":40,"periodsPerWeek":null,"course":{"id":142189,"code":"PHYS1008B","nameZh":"大学物理-基础实验B","nameEn":"College Physics – Base Experimentation B","totalPeriods":40,"theoryPeriods":0,"credits":1,"introduction":"<p>&ldquo;大学物理-基础实验&rdquo;是一门关于基本物理量的测量、基本实验仪器的使用、基本实验技能的训练和基本测量方法与误差分析的课程.课程涉及力学、热学、电磁学、光学和近代物理的基础性实验。实验内容包括基本物理量的测量(长度、时间、质量、电流、温度);直线运动、振动和波动； 基本物性测量;电路与电磁场的测量;光学测量和电子性质与基本常数的测量.</p>","courseGradation":"通修","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":56,"code":"042","nameZh":"物理实验教学中心"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":142164,"code":"PHYS1002A","nameZh":"热学A","nameEn":"Thermotics A","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程讲述热现象、热运动的宏观理论与微观理论的基础知识，内容包括热力学第零、第一、第二定律，热运动的统计规律，热传递，物质的热性质及相变。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":null,"periodsPerWeek":5,"course":{"id":10056,"code":"PHYS1004A","nameZh":"电磁学A","nameEn":"Electromagnetism A","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>电磁学A是一门关于电磁现象及电磁相互作用的课程，是自然科学重要基础课之一。内容涉及在真空、导体、介质中的静态和随时间演变的电场和磁场规律，主要章节包括电场、磁场、电磁力、导体与介质的电磁特性、电磁感应、直流电和交流电、麦克斯韦电磁方程组和电磁波。通过本课程学习，能深刻认识电磁现象的基本规律，掌握电磁相互作用的基本理论和应用，培养严密的科学思维能力，熟练掌握数学工具在电磁学中的应用， 以及了解电磁学在现代科学技术发展中的作用。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["1春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":null,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":142140,"code":"PHYS1001A","nameZh":"力学A","nameEn":"Mechanics A","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>力学是大学第一门普通物理课程，主要介绍与描述、研究物体机械运动有关的基本概念、基本理论和相关研究方法，包括质点运动学、牛顿动力学等，以及建立在此基础上关于振动与波、刚体、流体等的基本理论；除此之外，还简单介绍狭义相对论的基本内容。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":80,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":4,"course":{"id":142166,"code":"PHYS1003A","nameZh":"光学A","nameEn":"Optics A","totalPeriods":80,"theoryPeriods":80,"credits":4,"introduction":"<p>光学是物理学的重要组成部分，是研究光的本性，光的产生、传播、探测，光与物质相互作用，以及光在科学研究和技术中各种应用的一门基础学科。是理学专业的一门专业必修基础课程。</p>\r\n<p>本课程主要讲授光的几何理论以及光的电磁波动理论，包括：光线传播与几何成像，光的电磁特性，偏振，菲涅尔公式，干涉，衍射，傅里叶光学初步，光在晶体中的传播，光的吸收、色散和散射，以及光的量子性和激光。此外，也介绍光学研究领域的最新进展及其应用等。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["2秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}},{"compulsory":true,"weeks":18,"totalPeriods":40,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":4,"course":{"id":142169,"code":"PHYS1005B","nameZh":"原子物理B","nameEn":"Atomic Physics B","totalPeriods":40,"theoryPeriods":40,"credits":2,"introduction":"<p>原子物理课程主要讨论原子的结构和光谱，主要讲授原子模型、量子力学初步、单电子原子、多电子原子以及原子核的性质和结构等。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["2春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":87,"code":"203","nameZh":"物理学院"}}],"public":null,"ref":null,"index":5},"isLeaf":true},{"self":{"id":62721,"parent":62699,"type":"政治通修","typeEn":"Politics-General","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":17,"requiredCourseNum":7,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":null,"totalPeriods":80,"theoryPeriods":0,"praticePeriods":0,"experimentPeriods":80,"periodsPerWeek":0,"course":{"id":139694,"code":"MARX1005","nameZh":"思想政治理论课实践","nameEn":"Practice on Chinese Important Thoughts","totalPeriods":80,"theoryPeriods":0,"credits":2,"introduction":"<p>实践教学是思想政治理论课课堂教学的延伸拓展，重在帮助学生巩固课堂学习效果，深化对教学重点难点问题的理解和掌握。</p>\r\n<p>课程由学校相关部门精选有代表性的实践项目，结合思想政治理论课教学要求，引导学生参加实践活动，达到思想政治理论课实践教学的培养目标。实践项目组织单位将实践项目教学内容、组织形式、管理办法及考核方式等报送教务处，经学校审核批准后纳入&ldquo;思想政治理论课实践&rdquo;教学方案，并负责完成项目的教学组织和考核。学生可选择参加其中任一实践项目完成社会实践教学要求。</p>\r\n<p>实践环节成绩记载为二等级制，&ldquo;通过&rdquo;即获得2学分。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["3秋"],"remark":null,"examMode":"其他","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}},{"compulsory":true,"weeks":null,"totalPeriods":40,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":0,"course":{"id":139691,"code":"MARX1006","nameZh":"形势与政策(讲座)","nameEn":"Situation and Policy","totalPeriods":40,"theoryPeriods":40,"credits":2,"introduction":"<p>&ldquo;形势与政策&rdquo;课是理论武装时效性、释疑解惑针对性、教育引导综合性都很强的高校思想政治理论课，是帮助大学生正确认识新时代国内外形势，深刻领会党的十八大以来党和国家事业取得的历史性成就、发生的历史性变革、面临的历史性机遇和挑战的核心课程，是第一时间推动党的理论创新成果进教材进课堂进学生头脑，引导大学生准确理解党的基本理论、基本路线、基本方略的重要渠道。</p>\r\n<p>课程坚持马克思主义立场、观点和方法，结合中华民族发展史、中国共产党史、中华人民共和国史、改革开放史和世界社会主义发展史，结合大学生思想实际，重点讲授党的理论创新最新成果，重点讲授新时代坚持和发展中国特色社会主义的生动实践，科学分析当前形势与政策，准确阐释习近平新时代中国特色社会主义思想，引导学生正确认识世界和中国发展大势，正确认识中国特色和国际比较，正确认识时代责任和历史使命，正确认识远大抱负和脚踏实地。</p>\r\n<p>课程依据教育部每学期印发的《高校&ldquo;形势与政策&rdquo;课教学要点》，根据形势发展要求和学生特点有针对性地设置教学内容，及时回应学生关注的热点问题。教学形式灵活多样，主要包括马克思主义学院组织的&ldquo;习近平新时代中国特色社会主义思想&rdquo;系列讲座，同时包括由校党委宣传部、教务处、学工部、校团委等部门协同，组织校内外资源以党校集中面授、青年马克思主义工程、学生骨干培训等方式，开设的与&ldquo;形势与政策&rdquo;相关的讲座。</p>\r\n<p>课程要求提交课程报告，重点考核学生对马克思主义中国化最新成果的掌握水平，考核学生对新时代中国特色社会主义实践的了解情况。课程成绩评分制为二分制。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["3秋"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}},{"compulsory":true,"weeks":null,"totalPeriods":50,"theoryPeriods":50,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":2,"course":{"id":144404,"code":"MARX1010","nameZh":"中国近现代史纲要","nameEn":"An Outline of Modern and Contemporary Chinese History","totalPeriods":50,"theoryPeriods":50,"credits":2.5,"introduction":"<p>本课程的定位与性质：《中国近现代史纲要》课程，是2005年根据中央政治局的决定，中宣部、教育部下发的《关于进一步加强和改进高等学校思想政治理论课的意见》规定的大学生公共政治必修课程。</p>\r\n<p>本课程的课程内容：《中国的近现代史纲要》，以中国一代又一代的志士仁人和人民群众为救亡图存和实现中华民族的伟大复兴而英勇奋斗、艰苦探索的历史为主线，尤其是全国各族人民在中国共产党的领导下，进行伟大的艰苦的斗争，经过新民主主义革命，创建中华人民共和国，赢得民族独立和人民解放、经过社会主义革命、建设、改革，把一个极度贫弱的旧中国逐步变成一个持续走向繁荣富强、充满生机和活力的社会主义新中国的历史。内容主要涉及从鸦片战争到五四运动前夜(1840&mdash;1919)、从五四运动到新中国成立(1919&mdash;1949)、从新中国成立到社会主义现代化建设新时期(1949&mdash;2018)三个时期。</p>\r\n<p>本课程的考核方式：目前根据教学实际开展进行个性化考核（开卷考试、提交课程论文报告等方式），注重过程考核，根据学生出勤、听课、课程参与等情况，综合评定学期成绩。</p>\r\n<p>&nbsp;</p>","courseGradation":"通修","seasons":"春"},"terms":["1春"],"remark":null,"examMode":"笔试（开卷）","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}},{"compulsory":true,"weeks":18,"totalPeriods":50,"theoryPeriods":50,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":144405,"code":"MARX1011","nameZh":"马克思主义基本原理","nameEn":"Fundamentals of Marxism","totalPeriods":50,"theoryPeriods":50,"credits":2.5,"introduction":"<p>马克思主义是关于自然、社会和人类思维发展一般规律的学说，是关于社会主义必然代替资本主义、最终实现共产主义的学说，是关于无产阶级解放、全人类解放和每个人自由而全面发展的学说，是指引人民创造美好生活的行动指南。马克思主义哲学、马克思主义政治经济学和科学社会主义是马克思主义的三个基本组成部分，它们有机统一并共同构成了马克思主义理论的主体内容。马克思主义基本原理是对马克思主义立场、观点、方法的集中概括，是马克思主义在其形成、发展和运用过程中经过实践反复检验而确立起来的具有普遍真理性的理论。它体现马克思主义的根本性质和整体特征，体现马克思主义科学性和革命性的统一。</p>\r\n<p>&nbsp;&ldquo;马克思主义基本原理概论&rdquo;课程旨在全面准确阐释马克思主义基本原理，帮助学生从整体上把握马克思主义，正确认识人类社会发展的基本规律，树立科学的世界观、人生观、价值观，增强运用马克思主义立场、观点、方法分析问题、解决问题的能力，为学生确立对马克思主义的信仰、对中国特色社会主义共同理想的信念，自觉坚持党的基本理论、基本路线和基本方略打下扎实的理论基础。</p>\r\n<p>&nbsp;</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["2秋"],"remark":null,"examMode":"笔试（开卷）","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}},{"compulsory":true,"weeks":null,"totalPeriods":50,"theoryPeriods":50,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":144862,"code":"MARX1012","nameZh":"思想道德与法治","nameEn":"Ideology, Morality, and Rule of Law","totalPeriods":50,"theoryPeriods":50,"credits":2.5,"introduction":"<p>&ldquo;思想道德与法治&rdquo;是一门融思想性、政治性、科学性、理论性、实践性于一体的思想政治理论课。本课程针对大学生成长过程中面临的思想道德与法治问题，开展马克思主义的人生观、价值观、道德观、法治观教育，帮助大学生提升思想道德素质和法治素养，成长为自觉担当民族复兴大任的时代新人。</p>","courseGradation":"通修","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（开卷）","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}},{"compulsory":true,"weeks":null,"totalPeriods":50,"theoryPeriods":50,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":144863,"code":"MARX1013","nameZh":"毛泽东思想和中国特色社会主义理论体系概论","nameEn":"Introduction to Mao Zedong Thought and Theoretical System of Socialism with Chinese Characteristics","totalPeriods":50,"theoryPeriods":50,"credits":2.5,"introduction":"<p>&ldquo;毛泽东思想和中国特色社会主义理论体系概论&rdquo;是高校思想政治理论课的重要组成部分。本课程坚持理论与实践、历史与逻辑相统一，在把握马克思主义中国化时代化发展脉络的基础上，帮助学生全面准确地了解基本国情，系统掌握毛泽东思想、邓小平理论、&ldquo;三个代表&rdquo;重要思想、科学发展观的主要内容、精神实质、历史地位和指导意义，提高运用马克思主义立场、观点、方法分析和解决实际问题的能力，增强对中国特色社会主义道路自信、理论自信、制度自信和文化自信。</p>","courseGradation":"通修","seasons":"春"},"terms":["2春"],"remark":null,"examMode":"笔试（开卷）","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}},{"compulsory":true,"weeks":null,"totalPeriods":54,"theoryPeriods":54,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":144946,"code":"MARX1014","nameZh":"习近平新时代中国特色社会主义思想概论","nameEn":"Introduction to Xi Jinping Thought on Socialism with Chinese Characteristics for a New Era","totalPeriods":54,"theoryPeriods":54,"credits":3,"introduction":"<p><a href=\"&ldquo;习近平新时代中国特色社会主义思想概论&rdquo;是高校思想政治理论课的重要组成部分。本课程坚持理论与实践、历史与逻辑相统一，在厘清马克思主义中国化时代化发展脉络的基础上，帮助学生全面准确地了解基本国情，系统掌握习近平新时代中国特色社会主义思想的主要内容、精神实质、历史地位和指导意义，提高运用马克思主义立场、观点、方法分析和解决实际问题的能力，增强对中国特色社会主义道路自信、理论自信、制度自信、文化自信，坚定在党的领导下走中国特色社会主义道路和实现中华民族伟大复兴的理想信念。 本课程为本科必修课，54学时，3学分。成绩以百分制记载。\">&ldquo;习近平新时代中国特色社会主义思想概论&rdquo;是高校思想政治理论课的重要组成部分。本课程坚持理论与实践、历史与逻辑相统一，在厘清马克思主义中国化时代化发展脉络的基础上，帮助学生全面准确地了解基本国情，系统掌握习近平新时代中国特色社会主义思想的主要内容、精神实质、历史地位和指导意义，提高运用马克思主义立场、观点、方法分析和解决实际问题的能力，增强对中国特色社会主义道路自信、理论自信、制度自信、文化自信，坚定在党的领导下走中国特色社会主义道路和实现中华民族伟大复兴的理想信念。 本课程为本科必修课，54学时，3学分。成绩以百分制记载。 </a></p>","courseGradation":"通修","seasons":"秋"},"terms":["1秋"],"remark":null,"examMode":"笔试（开卷）","department":{"id":225,"code":"220","nameZh":"马克思主义学院"}}],"public":null,"ref":null,"index":6},"isLeaf":true},{"self":{"id":62722,"parent":62699,"type":"体育通修","typeEn":"Physical Education-General","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":4,"requiredCourseNum":4,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":554,"ref":null,"index":7},"isLeaf":false,"children":[{"self":{"id":62723,"parent":62722,"type":"必修","typeEn":"Compulsory Courses","major":"--","majorDirection":"--","remark":"基础体育","requiredSubModuleNum":0,"requiredCredits":1,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":40,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":2,"course":{"id":11512,"code":"PE00001","nameZh":"基础体育","nameEn":"Basic Sports","totalPeriods":40,"theoryPeriods":40,"credits":1,"introduction":"<p>（男）本课程传授简化二十四式太极拳，在音乐伴奏下进行的徒手练习。将学校体育教育和中国武术文化有效融合。通过练习，对外能利关节，强筋骨，壮体魄；对内理脏腑，调精神，修身养性。对调节内环境的平衡，身心调适，增强体质十分有益。达到增进健康，身心愉悦的目的。通过全面身体素质训练、健身跑全面提高学生的身心健康水平。</p>\r\n<p>（女）本课程是在音乐伴奏下进行的徒手练习，是一项以自然动作美和韵律性为基础，通过肢体动作展现自我，培养优雅举止和仪态的一项运动。主要学习形体所含的基本动作组合和正确的练习方法，包括手位、脚位、身体基本姿态以及各种舞蹈组合，掌握基本的美容方法、服饰搭配及仪态仪表的艺术。通过本课程的学习使学生得到优雅气质和风度的培养，达到健康优美的形体。通过全面身体素质训练、健身跑全面提高学生的身心健康水平。<br /><br /></p>","courseGradation":"通修","seasons":"秋"},"terms":["0--"],"remark":null,"examMode":"体育测试","department":{"id":81,"code":"103","nameZh":"体育教学中心"}}],"public":1072,"ref":null,"index":0},"isLeaf":true},{"self":{"id":62724,"parent":62722,"type":"选修","typeEn":"Selective","major":"--","majorDirection":"--","remark":"体育选项","requiredSubModuleNum":0,"requiredCredits":3,"requiredCourseNum":3,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":1073,"ref":null,"index":1},"isLeaf":true}]},{"self":{"id":62725,"parent":62699,"type":"计算机通修","typeEn":"Computer-General","major":"--","majorDirection":"--","remark":"分级考试进入相应班级","requiredSubModuleNum":0,"requiredCredits":8,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":null,"totalPeriods":100,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":40,"periodsPerWeek":null,"course":{"id":145916,"code":"AI1001A","nameZh":"人工智能数学原理与算法A","nameEn":"Mathematical Principles and Algorithms of Artificial Intelligence A","totalPeriods":100,"theoryPeriods":60,"credits":4,"introduction":"<p>本课程是一门面向全校本科学生的通修课程，讲授人工智能的基本原理、核心技术与应用场景，帮助学生建立对人工智能领域的初步认知与实践能力。课程以理论与实践相结合的方式，通过深入浅出的教学内容与丰富的实验环节，让学生掌握主流机器学习方法。</p>\r\n<ul>\r\n<li>理论课程涵盖人工智能的历史发展、核心概念及其实际应用场景。重点介绍监督学习中的经典算法（如线性回归、逻辑回归）、神经网络的基本架构与优化机制（如前向传播、反向传播、梯度消失与爆炸），以及深度学习中的前沿模型（如图神经网络和 Transformer）、自监督学习的核心思想、强化学习的基础理论、生成式人工智能的最新进展。</li>\r\n<li>实践课程是本课程的重要组成部分。学生将通过 Python 编程实现理论课程中讲授的经典算法，完成实际应用任务，如图像分类、文本处理、AI-for-Science等项目。通过实验操作，使学生不仅掌握数据处理、模型构建与优化等技能，还深入理解人工智能技术在解决实际问题时的流程与挑战。</li>\r\n</ul>\r\n<p>通过本课程的学习，学生将掌握人工智能领域的基础知识与实践技能，具备使用主流人工智能技术解决简单实际问题的能力，为未来深入学习或从事相关工作奠定基础。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["2春"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":142,"code":"229","nameZh":"人工智能与数据科学学院"}},{"compulsory":true,"weeks":18,"totalPeriods":80,"theoryPeriods":40,"praticePeriods":0,"experimentPeriods":40,"periodsPerWeek":4,"course":{"id":146394,"code":"CS1003","nameZh":"计算机程序设计","nameEn":"Computer Programming","totalPeriods":80,"theoryPeriods":40,"credits":3,"introduction":"<p>本课程以迭代的方式进行内容组织与教学实践，首先概述预备知识，并通过简单的示例快速引入最常用的C语言语法元素；然后基于C语言的成分阐述单模块程序设计方法，揭示计算思维中抽象与自动化的概念在结构化程序设计中的应用；接着基于函数阐述多模块程序设计方法，揭示计算思维中问题分解、接口设计等概念在模块化程序设计中的应用；最后基于指针阐述内存对象的操作，揭示计算思维在程序设计与运行底层的融入机制。本课程注重知识体系的建立、原理本质的解析、学习过程的考核，以期实现对学生综合能力素质的培养。</p>","courseGradation":"通修","seasons":"秋,春"},"terms":["1秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":93,"code":"210","nameZh":"信息科学技术学院"}}],"public":null,"ref":null,"index":8},"isLeaf":true}]},{"self":{"id":63898,"parent":62698,"type":"专业基础课程","typeEn":"Professional Basic Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":0,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[],"public":null,"ref":null,"index":1},"isLeaf":false,"children":[{"self":{"id":63900,"parent":63898,"type":"专业基础课程","typeEn":"Professional Basic Courses","major":"地球物理学","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":3,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":null,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":140348,"code":"219002","nameZh":"数字信号处理B","nameEn":"Digital Signal Processing B","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程讲授数字信号处理基本理论和实现方法。内容上衔接信号与系统课程，并逐步过渡到为在数字设备上实现数字信号处理而需要的离散傅立叶变换（DFT）及其快速计算（FFT）；接下来是与系统分析有关的内容，包括离散时间系统的相位、结构与逆系统；最后是无限/有限冲激响应数字滤波器设计，这是与系统设计有关的内容。</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["3秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":614,"code":"219","nameZh":"集成电路学院（国家示范性微电子学院）"}}],"public":null,"ref":null,"index":0},"isLeaf":true},{"self":{"id":63899,"parent":63898,"type":"专业基础课程","typeEn":"Professional Basic Courses","major":"空间科学与技术","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":3,"requiredCourseNum":1,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":null,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":140348,"code":"219002","nameZh":"数字信号处理B","nameEn":"Digital Signal Processing B","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本课程讲授数字信号处理基本理论和实现方法。内容上衔接信号与系统课程，并逐步过渡到为在数字设备上实现数字信号处理而需要的离散傅立叶变换（DFT）及其快速计算（FFT）；接下来是与系统分析有关的内容，包括离散时间系统的相位、结构与逆系统；最后是无限/有限冲激响应数字滤波器设计，这是与系统设计有关的内容。</p>","courseGradation":"专业基础","seasons":"秋,春"},"terms":["3秋"],"remark":null,"examMode":"笔试（闭卷）","department":{"id":614,"code":"219","nameZh":"集成电路学院（国家示范性微电子学院）"}}],"public":null,"ref":null,"index":1},"isLeaf":true}]},{"self":{"id":62726,"parent":62698,"type":"专业核心课程","typeEn":"Major Courses","major":"--","majorDirection":"--","remark":null,"requiredSubModuleNum":0,"requiredCredits":5,"requiredCourseNum":3,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":true,"weeks":18,"totalPeriods":20,"theoryPeriods":20,"praticePeriods":0,"experimentPeriods":0,"periodsPerWeek":1,"course":{"id":14905,"code":"208702","nameZh":"地球系统科学讲座","nameEn":"Seminar in Earth System Science","totalPeriods":20,"theoryPeriods":20,"credits":1,"introduction":"<p>组织英才班学生3春赴中科院地质与地球物理研究所，由研究所组织高水平研究人员为英才班学生做地球系统科学方面的系列讲座，与学生研讨地球系统科学相关的前沿问题，并向学生介绍相关科学研究方法和科学仪器设备；学生选取其中的两个讲座撰写总结或前沿进展报告, 每个报告字数不少于1000字,或者只选取其中一个讲座撰写报告，字数不少于2500字（不包括参考文献）。</p>","courseGradation":"专业核心","seasons":"春"},"terms":["3春"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":91,"code":"208","nameZh":"地球和空间科学学院"}},{"compulsory":true,"weeks":18,"totalPeriods":40,"theoryPeriods":0,"praticePeriods":40,"experimentPeriods":0,"periodsPerWeek":1,"course":{"id":8598,"code":"208703","nameZh":"野外与实践","nameEn":"Field andPractice","totalPeriods":40,"theoryPeriods":0,"credits":1,"introduction":"<p>要求英才班学生四年内至少参加该课程组织的野外／研究院所实习实践活动中的4次，每次实习结束后两周内要求提交不少于800字的实习总结报告，第四年秋季学期根据学生整体的实习表现、参与次数和实习报告质量给出最终成绩</p>","courseGradation":"专业核心","seasons":"秋"},"terms":["4秋"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":91,"code":"208","nameZh":"地球和空间科学学院"}},{"compulsory":true,"weeks":18,"totalPeriods":60,"theoryPeriods":60,"praticePeriods":null,"experimentPeriods":0,"periodsPerWeek":3,"course":{"id":8597,"code":"208701","nameZh":"交叉研究实践","nameEn":"Interdisciplinary Research Practice","totalPeriods":60,"theoryPeriods":60,"credits":3,"introduction":"<p>本科阶段的科学研究是培养学生科研思维能力和科学兴趣的一个重要环节，对今后培养优秀的科研人才具有重要意义。本课程面向大三年级的地空学院英才班学生，通过老师授课、学生开展一年的科研实践、师生共同研讨等方式提高学生开展交叉科学研究的能力、科学论文撰写的能力以及进行学术报告和学术交流活动的能力。</p>","courseGradation":"专业核心","seasons":"秋,春"},"terms":["3秋"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":91,"code":"208","nameZh":"地球和空间科学学院"}}],"public":null,"ref":null,"index":2},"isLeaf":true},{"self":{"id":62727,"parent":62698,"type":"专业选修课程","typeEn":"Major Selectives","major":"--","majorDirection":"--","remark":"在导师指导下选修4个学分主修专业之外的其他专业（建议选择地空学院下设专业）的专业核心课","requiredSubModuleNum":0,"requiredCredits":4,"requiredCourseNum":0,"creditsUpperLimit":null,"courseNumUpperLimit":null,"courses":[{"compulsory":false,"weeks":null,"totalPeriods":60,"theoryPeriods":20,"praticePeriods":40,"experimentPeriods":0,"periodsPerWeek":null,"course":{"id":146151,"code":"ESS4702","nameZh":"地球系统野外综合实习","nameEn":"Integrated Field Study of Earth System Science","totalPeriods":60,"theoryPeriods":20,"credits":2,"introduction":"<p>地球系统科学野外综合实习面向地空学院赵九章英才班大二学生。实习把课堂讲授和野外考察结合，以法国阿尔卑斯地区为例，让学生直观认识俯冲带大地构造现象，深入理解地球系统变化规律与机理。课程前期讲授岩石、矿物、构造等地质学背景知识，介绍法国阿尔卑斯地区的地质背景，为野外考察和研讨打基础。野外实习围绕板块构造、火山地震、冰川地貌、大气和空间观测开展教学，学生实地研讨地质现象、地形地貌形成机制，理解地球各圈层的相互作用。课程用英文讲授。</p>","courseGradation":"专业选修","seasons":"夏"},"terms":["2夏"],"remark":null,"examMode":"大作业（论文、报告、项目或作品等）","department":{"id":91,"code":"208","nameZh":"地球和空间科学学院"}}],"public":null,"ref":null,"index":3},"isLeaf":true}]}